# Example production environment for sensoriumd.
#
# Copy to /etc/default/sensoriumd and adjust if your deployment uses different
# state or install paths.

SENSORIUM_STATE_DIR=/var/lib/sensorium
# Optional overrides. The unit already defaults to the paths below.
# SENSORIUM_SOCKET_PATH=/run/sensorium/sensoriumd.sock
# SENSORIUM_PIDFILE_PATH=/run/sensorium/sensoriumd.pid
