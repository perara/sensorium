config VIDEO_SENSORIUM
	tristate "Sensorium virtual camera simulator"
	depends on VIDEO_DEV && VIDEO_V4L2_SUBDEV_API && MEDIA_CONTROLLER
	select VIDEOBUF2_VMALLOC
	select VIDEOBUF2_DMA_SG
	help
